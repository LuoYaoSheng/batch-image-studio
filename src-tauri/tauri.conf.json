{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Batch Image Studio",
  "version": "0.1.1",
  "identifier": "studio.batchimage.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Batch Image Studio",
        "width": 1720,
        "height": 1040,
        "minWidth": 1420,
        "minHeight": 880,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../resources/models/": "models/",
      "scripts/": "scripts/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
